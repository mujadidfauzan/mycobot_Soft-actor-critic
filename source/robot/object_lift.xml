<mujoco model="lift object scene">
    
  <option timestep="0.002" gravity="0 0 -9.81" noslip_iterations="3"/>
    
    <include file="robot.xml"/>


    <default>
        <geom solref="0.001 1" solimp="0.99 0.99 0.001"/>
    </default>

    <visual>
      <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
      <rgba haze="0.15 0.25 0.35 1"/>
      <global azimuth="120" elevation="-20"/>
    </visual>
  
    <asset>
      <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
      <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
      <material name="groundplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true"/>
      <material name="obj_material" rgba="0.8 0.2 0.2 1" />
    </asset>
  
    <worldbody>
      <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
      <camera name="watching" pos="1.669 -1.154 1.019" xyaxes="0.644 0.765 0.000 -0.250 0.210 0.945"/>

      <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  
      <body name="floor" pos="0. 0. 0.">
        <site name="target" pos="0.3 0.0 0.2" size=".02 .02 .02" rgba="1 0.0 0.0 1" type="sphere"/>
      </body>
  
      <body name="obj" pos="0.0 0.3 0.0">
            <freejoint name="_joint"/>
            <geom name="obj_geom" type="box" size="0.015 0.015 0.015" mass="0.03" material="obj_material" />
            <site name="obj_frame"
              pos="0 0 0"
              quat="1 0 0 0"
              size="0.01"
              rgba="0 1 0 1"
              type="sphere"/>
      </body>
  
    </worldbody>
    
  </mujoco>
  