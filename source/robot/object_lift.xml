<mujoco model="lift object scene">
    
  <option timestep="0.002" gravity="0 0 -9.81" noslip_iterations="3"/>
    
    <include file="robot.xml"/>


    <default>
        <geom solref="0.001 1" solimp="0.99 0.99 0.001"/>
    </default>

    <visual>
      <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
      <rgba haze="0.15 0.25 0.35 1"/>
      <global azimuth="120" elevation="-20"/>
    </visual>
  
    <asset>
      <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
      <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
      <material name="groundplane" reflectance="0." texture="texplane" texrepeat="1 1" texuniform="true"/>
      <material name="cube_mat" rgba="0.8 0.2 0.2 1"/>
      <material name="tri_mat" rgba="0.2 0.8 0.2 1"/>
      <material name="cyl_mat" rgba="0.2 0.2 0.8 1"/>
      <material name="place_mat" rgba="0.8 0.8 0.8 1"/>
      <mesh name="triangle_mesh" file="../object_external/triangle.stl" scale="0.001 0.001 0.001"/>
      <mesh name="cylinder_mesh" file="../object_external/cylindar.stl" scale="0.001 0.001 0.001"/>
      <mesh name="cube_place_mesh" file="../object_external/cube_place.stl" scale="0.001 0.001 0.001"/>
      <mesh name="tri_place_mesh" file="../object_external/tri_place.stl" scale="0.001 0.001 0.001"/>
      <mesh name="cyl_place_mesh" file="../object_external/cylindrical_place.stl" scale="0.001 0.001 0.001"/>
    </asset>
  
    <worldbody>
      <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
      <camera name="watching" pos="1.669 -1.154 1.019" xyaxes="0.644 0.765 0.000 -0.250 0.210 0.945"/>

      <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
  
      <body name="floor" pos="0. 0. 0.">
        <site name="target" pos="0.3 0.0 0.2" size=".02 .02 .02" rgba="1 0.0 0.0 1" type="sphere"/>
      </body>
  
  
      <body name="cube_obj" pos="0.0 0.3 0.0">
      <freejoint name="cube"/>
      <geom name="cube_geom" type="box" size="0.015 0.015 0.015" mass="0.03" material="cube_mat" />
      <site name="cube_frame" pos="0 0 0" quat="1 0 0 0" size="0.01" rgba="0 1 0 1" type="sphere"/> 
      </body>

      <body name="triangle_obj" pos="0.27 0.04 0.05">
        <freejoint name="triangle_joint"/>
        <geom name="triangle_geom" type="mesh" mesh="triangle_mesh" mass="0.03" material="tri_mat"/>
        <site name="triangle_frame" pos="0 0 0.01" size="0.01" rgba="0 1 0 1" type="sphere"/>
      </body>

      <body name="cylinder_obj" pos="0.27 -0.04 0.05">
        <freejoint name="cylinder_joint"/>
        <geom name="cylinder_geom" type="mesh" mesh="cylinder_mesh" mass="0.03" material="cyl_mat"/>
        <site name="cylinder_frame" pos="0 0 0.01" size="0.01" rgba="0 0 1 1" type="sphere"/>
      </body>

      <!-- Place targets (hole/tray meshes). The env sets the 'target' site to 4cm above one of these. -->
      <body name="cube_place" pos="0.23 0.10 0.0">
        <!-- `cube_place.stl` has an off-center mesh origin; `pos` recenters it to the body frame -->
        <geom name="cube_place_geom" type="mesh" mesh="cube_place_mesh" material="place_mat" contype="0" conaffinity="0" pos="-0.1446836 -0.1472719 0.00"/>
        <site name="cube_place_site" pos="0.015 0 0.02" size="0.006" rgba="1 1 0 1" type="sphere"/>
      </body>

      <body name="tri_place" pos="0.23 0.00 0.0">
        <geom name="tri_place_geom" type="mesh" mesh="tri_place_mesh" material="place_mat" contype="0" conaffinity="0"/>
        <site name="tri_place_site" pos="0.015 0 0.02" size="0.006" rgba="1 1 0 1" type="sphere"/>
      </body>

      <body name="cyl_place" pos="0.23 -0.10 0.0">
        <geom name="cyl_place_geom" type="mesh" mesh="cyl_place_mesh" material="place_mat" contype="0" conaffinity="0" pos="-0.0025 0 0.00"/>
        <site name="cyl_place_site" pos="0.015 0 0.02" size="0.006" rgba="1 1 0 1" type="sphere"/>
      </body>


      <!-- TEST Model -->
      <!-- <body name="obj" pos="0.27 -0.04 0.05">
        <freejoint name="_joint"/>
        <geom name="obj_geom" type="mesh" mesh="triangle_mesh" mass="0.03" material="cyl_mat"/>
        <site name="obj_frame" pos="0 0 0.01" size="0.01" rgba="0 0 1 1" type="sphere"/>
      </body>  -->
    </worldbody>
    
  </mujoco>
  
