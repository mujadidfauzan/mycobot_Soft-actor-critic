<?xml version="1.0"?>
<robot name="mycobot">
  <mujoco>
    <compiler meshdir="meshes/" strippath="true"/>
  </mujoco>

  <material name="gray_metal">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

  <material name="pink_gripper">
    <color rgba="1.0 0.4 0.7 1.0"/>
  </material>

  <link name="link1">
    <visual>
      <geometry><mesh filename="meshes/link1.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/link1.stl" scale="0.001 0.001 0.001"/></geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="2.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="link2">
    <visual>
      <geometry><mesh filename="meshes/link2.stl"/></geometry>
      <origin xyz="0.0 0 -0.06096" rpy="0 0 -1.5708"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/link2.stl"/></geometry>
      <origin xyz="0.0 0 -0.06096" rpy="0 0 -1.5708"/>
    </collision>
    <inertial>
      <mass value="1.5"/><origin xyz="0 0 0" rpy="0 0 0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="link3">
    <visual>
      <geometry><mesh filename="meshes/link3.stl"/></geometry>
      <origin xyz="0.0 0 0.03256" rpy="0 -1.5708 0"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/link3.stl"/></geometry>
      <origin xyz="0.0 0 0.03256" rpy="0 -1.5708 0"/>
    </collision>
    <inertial>
      <mass value="1.2"/><origin xyz="0 0 0" rpy="0 0 0"/><inertia ixx="0.008" ixy="0" ixz="0" iyy="0.008" iyz="0" izz="0.008"/>
    </inertial>
  </link>

  <link name="link4">
    <visual>
      <geometry><mesh filename="meshes/link4.stl"/></geometry>
      <origin xyz="0.0 0 0.03056" rpy="0 -1.5708 0"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/link4.stl"/></geometry>
      <origin xyz="0.0 0 0.03056" rpy="0 -1.5708 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/><origin xyz="0 0 0" rpy="0 0 0"/><inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <link name="link5">
    <visual>
      <geometry><mesh filename="meshes/link5.stl"/></geometry>
      <origin xyz="0.0 -0.001 -0.0345" rpy="0 -1.5708 1.5708"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/link5.stl"/></geometry>
      <origin xyz="0.0 -0.001 -0.0345" rpy="0 -1.5708 1.5708"/>
    </collision>
    <inertial>
      <mass value="0.8"/><origin xyz="0 0 0" rpy="0 0 0"/><inertia ixx="0.003" ixy="0" ixz="0" iyy="0.003" iyz="0" izz="0.003"/>
    </inertial>
  </link>

  <link name="link6">
    <visual>
      <geometry><mesh filename="meshes/link6.stl"/></geometry>
      <origin xyz="0 0.00 -0.038" rpy="0 0 0"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/link6.stl"/></geometry>
      <origin xyz="0 0.00 -0.038" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/><origin xyz="0 0 0" rpy="0 0 0"/><inertia ixx="0.002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>

  <link name="link6_flange">
    <visual>
      <geometry><mesh filename="meshes/flange.stl"/></geometry>
      <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
      <material name="gray_metal"/>
    </visual>
    <collision>
      <geometry><mesh filename="meshes/flange.stl"/></geometry>
      <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.2"/><origin xyz="0 0 0" rpy="0 0 0"/><inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>

  <link name="gripper_base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pink_gripper"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/base_link.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.0016796 0.0004611 0.013974" rpy="0 0 0"/><mass value="0.1"/>
      <inertia ixx="8.668e-06" iyy="5.810e-06" izz="4.883e-06" ixy="-5.11e-08" iyz="6.118e-08" ixz="-6.603e-07"/>
    </inertial>
  </link>

  <link name="finrayLeft2">
    <visual>
      <origin xyz="-0.00605 0.041829 -0.05536" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/finrayLeft2.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pink_gripper"/>
    </visual>
    <collision>
      <origin xyz="-0.00605 0.041829 -0.05536" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/finrayLeft2.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial><mass value="0.02"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <link name="finrayRight1">
    <visual>
      <origin xyz="-0.00605 -0.043561 -0.05558" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/finrayRight1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pink_gripper"/>
    </visual>
    <collision>
      <origin xyz="-0.00605 -0.043561 -0.05558" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/finrayRight1.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial><mass value="0.02"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <link name="gearLeft1">
    <visual>
      <origin xyz="-0.00605 0.016296 -0.021707" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/gearLeft1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pink_gripper"/>
    </visual>
    <collision>
      <origin xyz="-0.00605 0.016296 -0.021707" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/gearLeft1.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <link name="gearRight1">
    <visual>
      <origin xyz="-0.00605 -0.018241 -0.021707" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/gearRight1.stl" scale="0.001 0.001 0.001"/></geometry>
      <material name="pink_gripper"/>
    </visual>
    <collision>
      <origin xyz="-0.00605 -0.018241 -0.021707" rpy="0 0 0"/>
      <geometry><mesh filename="meshes/gearRight1.stl" scale="0.001 0.001 0.001"/></geometry>
    </collision>
    <inertial><mass value="0.01"/><inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/></inertial>
  </link>

  <joint name="link2_to_link1" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.9321" upper="2.9321" velocity="1.0"/>
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.13956" rpy="0 0 0"/>
  </joint>

  <joint name="link3_to_link2" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.3561" upper="2.3561" velocity="1.0"/>
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 -0.001" rpy="0 1.5708 -1.5708"/>
  </joint>

  <joint name="link4_to_link3" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.6179" upper="2.6179" velocity="1.0"/>
    <parent link="link3"/>
    <child link="link4"/>
    <origin xyz="-0.1104 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="link5_to_link4" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.5307" upper="2.5307" velocity="1.0"/>
    <parent link="link4"/>
    <child link="link5"/>
    <origin xyz="-0.096 0 0.06462" rpy="0 0 -1.5708"/>
  </joint>

  <joint name="link6_to_link5" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-2.8797" upper="2.8797" velocity="1.0"/>
    <parent link="link5"/>
    <child link="link6"/>
    <origin xyz="0 -0.07318 -0.001" rpy="1.5708 -1.5708 0"/>
  </joint>

  <joint name="link6output_to_link6" type="revolute">
    <axis xyz="0 0 1"/>
    <limit effort="1000.0" lower="-3.14" upper="3.14159" velocity="1.0"/>
    <parent link="link6"/>
    <child link="link6_flange"/>
    <origin xyz="0 0.0456 0" rpy="-1.5708 0 0"/>
  </joint>

  <joint name="flange_to_gripper" type="fixed">
    <parent link="link6_flange"/>
    <child link="gripper_base_link"/>
    <origin xyz="0 0 0.0074" rpy="0 0 -1.5"/>
  </joint>


  <joint name="base_gearLeft" type="revolute">
    <origin xyz="0.00605 -0.016296 0.021707" rpy="0 0 0"/>
    <parent link="gripper_base_link"/>
    <child link="gearLeft1"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit lower="-0.7" upper="0" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="gear_finrayLeft" type="fixed">
    <origin xyz="0.0 -0.025533 0.033653" rpy="0 0 0"/>
    <parent link="gearLeft1"/>
    <child link="finrayLeft2"/>
    <axis xyz="1.0 -0.0 0.0"/>
    <limit lower="0" upper="1.0" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="base_gearRight" type="revolute">
    <origin xyz="0.00605 0.018241 0.021707" rpy="0 0 0"/>
    <parent link="gripper_base_link"/>
    <child link="gearRight1"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit lower="0" upper="0.7" effort="10.0" velocity="1.0"/>
  </joint>

  <joint name="gear_finrayRight" type="fixed">
    <origin xyz="0.0 0.02532 0.033873" rpy="0 0 0"/>
    <parent link="gearRight1"/>
    <child link="finrayRight1"/>
    <axis xyz="1.0 -0.0 0.0"/>
    <limit lower="-1.0" upper="0" effort="10.0" velocity="1.0"/>
  </joint>

</robot>
